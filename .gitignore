# Version control
.git
.gitignore
.gitattributes

# CI/CD & Development
.gitlab-ci.yml
.vscode
.vs

# IDEs
*.swp
*.swo
*~
.DS_Store

# Build output (per service)
**/bin/
**/obj/
**/out/

# NuGet cache (allow .csproj files)
packages/
