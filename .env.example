# Copie para Simcag.ProcessingService.Api/.env. Variáveis com __ (conforme Program.cs).
#
# Docker: DB__HOST/RABBITMQ__HOST=host.docker.internal, guest/guest, database processingdb

# RabbitMQ (RABBITMQ__HOST e credenciais são obrigatórias no arranque)
RABBITMQ__HOST=localhost
RABBITMQ__PORT=5672
RABBITMQ__USERNAME=guest
RABBITMQ__PASSWORD=guest
RABBITMQ__VIRTUALHOST=/

# PostgreSQL (DB__* montam a connection string; obrigatórias)
DB__HOST=localhost
DB__PORT=5432
DB__NAME=simcag_processing
DB__USER=postgres
DB__PASSWORD=postgres
